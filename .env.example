# ---- Database ----
POSTGRES_USER=objectifs
POSTGRES_PASSWORD=objectifs
POSTGRES_DB=objectifs
POSTGRES_PORT=5432

# ---- Ports exposed on the host ----
BACKEND_PORT=4000
FRONTEND_PORT=8080

# ---- Backend ----
# Re-run the seed on every backend start (safe: seed is idempotent). Set to false in prod.
RUN_SEED=true
# Origin(s) allowed by CORS (comma-separated). Includes the Vite dev server (5173).
CORS_ORIGIN=http://localhost:8080,http://localhost:5173
# Where the SPA is served (used to redirect back after Google OAuth)
APP_BASE_URL=http://localhost:8080

# ---- Frontend build ----
# Base URL the browser uses to reach the API
VITE_API_BASE=http://localhost:4000/api

# ---- Google Calendar sync (optional) ----
# Create an OAuth 2.0 Client (type "Web application") in Google Cloud Console.
# See README > "Configurer la synchronisation Google Agenda".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/sync/google/callback

# ---- Postgres SSL ----
# Set to true when connecting to a managed database that requires SSL
# (e.g. Render). Leave empty for the local Docker Postgres.
DATABASE_SSL=

# ---- Render deployment (used by `npm run deploy`) ----
# Option A — Deploy Hooks (Render dashboard → service → Settings → Deploy Hook):
RENDER_DEPLOY_HOOK_BACKEND=
RENDER_DEPLOY_HOOK_FRONTEND=
# Option B — Render API (alternative to hooks):
# RENDER_API_KEY=
# RENDER_SERVICE_ID_BACKEND=
# RENDER_SERVICE_ID_FRONTEND=
